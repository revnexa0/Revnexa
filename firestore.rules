rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Messages: anyone can create, only authenticated admins can read/update/delete
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if true; // TODO: Add authentication check
      // Production: allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Blog posts: anyone can read, only admins can write
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if true; // TODO: Add authentication check
      // Production: allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Settings: only admins can read/write
    match /settings/{settingId} {
      allow read, write: if true; // TODO: Add authentication check
      // Production: allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Newsletter subscriptions: anyone can create, only admins can read
    match /newsletter/{subId} {
      allow create: if true;
      allow read, delete: if true; // TODO: Add authentication check
      // Production: allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
